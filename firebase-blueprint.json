{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A scanned product record",
      "type": "object",
      "properties": {
        "barcode": {
          "type": "string",
          "description": "The scanned barcode value"
        },
        "name": {
          "type": "string",
          "description": "The product name"
        },
        "photoUrl": {
          "type": "string",
          "description": "The Firebase Storage photo URL"
        },
        "category": {
          "type": "string",
          "description": "The category of the product"
        },
        "costPrice": {
          "type": "number",
          "description": "The price at which the item is bought"
        },
        "sellingPrice": {
          "type": "number",
          "description": "The price at which the item is sold"
        },
        "quantity": {
          "type": "number",
          "description": "The current stock quantity"
        },
        "unit": {
          "type": "string",
          "description": "The unit of measurement"
        },
        "userId": {
          "type": "string",
          "description": "The owner UID"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last updated timestamp"
        }
      },
      "required": ["barcode", "name", "costPrice", "sellingPrice", "quantity", "unit", "userId", "createdAt", "updatedAt"]
    },
    "StockMovement": {
      "title": "StockMovement",
      "description": "A record of stock changes",
      "type": "object",
      "properties": {
        "productId": {
          "type": "string",
          "description": "The product document ID reference"
        },
        "type": {
          "type": "string",
          "enum": ["restock", "sale", "adjustment"],
          "description": "The movement type"
        },
        "quantityChange": {
          "type": "number",
          "description": "Change in stock count"
        },
        "priceAtTime": {
          "type": "number",
          "description": "Cost or selling price at the time of movement"
        },
        "userId": {
          "type": "string",
          "description": "The owner UID"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Movement timestamp"
        }
      },
      "required": ["productId", "type", "quantityChange", "priceAtTime", "userId", "timestamp"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products scoped to owners"
    },
    "/stockMovements/{movementId}": {
      "schema": "StockMovement",
      "description": "Collection of stock movements scoped to owners"
    }
  }
}
